  "bodyHtml": "<main class=\"product-page resource-detail-page\">\n      <section class=\"section resource-detail-hero\" aria-labelledby=\"resource-title\">\n        <p class=\"eyebrow\">宣传册</p>\n        <h1 id=\"resource-title\">AI 光学分拣系统宣传册</h1>\n        <p class=\"hero-copy\">为评估PET瓶、HDPE瓶、PP及混合可回收塑料的AI识别和光学分拣的团队提供的产品概览。</p>\n        <div class=\"resource-meta-row\" aria-label=\"资源元数据\">\n          <span>类型：产品手册</span>\n          <span>更新时间：2026-06-30</span>\n          <span>买家匹配：塑料回收项目</span>\n          <span>评测时间：10 min</span>\n        </div>\n      </section>\n\n      <section class=\"section resource-detail-layout\" aria-labelledby=\"coverage-title\">\n        <article class=\"resource-detail-panel\">\n          <h2 id=\"coverage-title\">本资源涵盖内容</h2>\n          <ul class=\"feature-list\">\n            <li>典型的可回收塑料原料与分类</li>\n            <li>PET、HDPE、PP和混合塑料分拣的系统定位</li>\n            <li>吞吐量、占地面积与自动化讨论点</li>\n            <li>在申请塑料分拣提案前需要准备的问题</li>\n          </ul>\n        </article>\n        <aside class=\"resource-detail-panel\">\n          <h2>何时使用此资源</h2>\n          <p>当你需要比较AI光学分拣与手工分拣或传统塑料回收线分离方法时，可以使用这本宣传册。</p>\n          <a class=\"primary-button\" href=\"/contact\">请求此资源</a>\n        </aside>\n      </section>\n\n      <section class=\"section\" aria-labelledby=\"related-title\">\n        <div class=\"section-heading\">\n          <p class=\"eyebrow\">相关资源</p>\n          <h2 id=\"related-title\">规划一个塑料分类项目</h2>\n          <p>在发送材料前，请先阅读产品页面、清单和联系表格。</p>\n        </div>\n        <div class=\"resource-related-grid\">\n          <a href=\"/products/ai-optical-sorting\">\n            AI 光学分拣产品页面\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n          <a href=\"/resources/project-inquiry-checklist\">\n            项目调查清单\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n          <a href=\"/resources/product-specification-sheet\">\n            产品规格表\n         