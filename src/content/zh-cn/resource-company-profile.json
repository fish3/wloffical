  "bodyHtml": "<main class=\"product-page resource-detail-page\">\n      <section class=\"section resource-detail-hero\" aria-labelledby=\"resource-title\">\n        <p class=\"eyebrow\">公司资源</p>\n        <h1 id=\"resource-title\">公司简介</h1>\n        <p class=\"hero-copy\">为买家提供简明的 供应商 概述，比较 WEI LAN 的制造重点、智能分拣系统、资质及海外项目 支持。</p>\n        <div class=\"resource-meta-row\" aria-label=\"资源元数据\">\n          <span>类型：公司档案</span>\n          <span>更新时间：2026-06-30</span>\n          <span>买家匹配度：采购与管理审查</span>\n          <span>评测时间：8 min</span>\n        </div>\n      </section>\n\n      <section class=\"section resource-detail-layout\" aria-labelledby=\"coverage-title\">\n        <article class=\"resource-detail-panel\">\n          <h2 id=\"coverage-title\">本资源涵盖内容</h2>\n          <ul class=\"feature-list\">\n            <li>WEI LAN公司定位与环境技术重点</li>\n            <li>AI光学分类与C&D 废弃物回收产品范围</li>\n            <li>制造、研发、认证和质量控制的证明点</li>\n            <li>海外回收设备采购项目讨论流程</li>\n          </ul>\n        </article>\n        <aside class=\"resource-detail-panel\">\n          <h2>何时使用此资源</h2>\n          <p>当团队在请求宣传册、证书或技术提案前，需要初始的 供应商 资格文件时，请使用公司档案。</p>\n          <a class=\"primary-button\" href=\"/contact\">请求此资源</a>\n        </aside>\n      </section>\n\n      <section class=\"section\" aria-labelledby=\"related-title\">\n        <div class=\"section-heading\">\n          <p class=\"eyebrow\">相关资源</p>\n          <h2 id=\"related-title\">继续 供应商 评估</h2>\n          <p>从公司评审转向产品比较、解决方案匹配或报价书准备。</p>\n        </div>\n        <div class=\"resource-related-grid\">\n          <a href=\"/resources/ai-optical-sorting-system-brochure\">\n            AI 光学分拣系统宣传册\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n          <a href=\"/resources/construction-waste-recycling-line-brochure\">\n            建筑废物回收线路宣传册\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n          <a href=\"/about\">\n            关于WEI LAN\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n          <a href=\"/contact\">\n            发送 项目 详情\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n        </div>\n      </section>\n    </main>"
