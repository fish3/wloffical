  "bodyHtml": "<main class=\"product-page resource-detail-page\">\n      <section class=\"section resource-detail-hero\" aria-labelledby=\"resource-title\">\n        <p class=\"eyebrow\">公司資源</p>\n        <h1 id=\"resource-title\">公司簡介</h1>\n        <p class=\"hero-copy\">為買家提供簡明的 供應商 概述，比較 WEI LAN 的製造重點、智慧分揀系統、憑證及海外專案 支援。</p>\n        <div class=\"resource-meta-row\" aria-label=\"資源元資料\">\n          <span>類型：公司檔案</span>\n          <span>更新：2026-06-30</span>\n          <span>買家契合：採購與管理審查</span>\n          <span>評論時間：8 min</span>\n        </div>\n      </section>\n\n      <section class=\"section resource-detail-layout\" aria-labelledby=\"coverage-title\">\n        <article class=\"resource-detail-panel\">\n          <h2 id=\"coverage-title\">本資源涵蓋內容</h2>\n          <ul class=\"feature-list\">\n            <li>WEI LAN公司定位與環境科技焦點</li>\n            <li>AI 光學分揀與C&D 廢棄物回收產品範圍</li>\n            <li>製造、研發、認證與品質控管的證明點</li>\n            <li>海外回收設備買家的專案討論流程</li>\n          </ul>\n        </article>\n        <aside class=\"resource-detail-panel\">\n          <h2>何時使用此資源</h2>\n          <p>當您的團隊需要初始的 供應商 資格檔案，再申請手冊、證書或技術提案時，請使用該公司檔案。</p>\n          <a class=\"primary-button\" href=\"/contact\">請求此資源</a>\n        </aside>\n      </section>\n\n      <section class=\"section\" aria-labelledby=\"related-title\">\n        <div class=\"section-heading\">\n          <p class=\"eyebrow\">相關資源</p>\n          <h2 id=\"related-title\">繼續 供應商 評估</h2>\n          <p>從公司評審轉向產品比較、解決方案配合或徵求書準備。</p>\n        </div>\n        <div class=\"resource-related-grid\">\n          <a href=\"/resources/ai-optical-sorting-system-brochure\">\n            AI 光學分揀系統手冊\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n          <a href=\"/resources/construction-waste-recycling-line-brochure\">\n            C&D 廢棄物回收管線手冊\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n          <a href=\"/about\">\n            關於WEI LAN\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n          <a href=\"/contact\">\n            傳送 專案 詳情\n            <span class=\"resource-related-cta\" aria-hidden=\"true\">探索</span>\n          </a>\n        </div>\n      </section>\n    </main>"
